{
  "expo": {
    "name": "FutureIntern",
    "slug": "futureintern",
    "version": "1.0.0",
    "scheme": "futureintern",
    "orientation": "portrait",
    "icon": "./assets/futureintern-logo.jpg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/futureintern-logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futureintern.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "FutureIntern needs access to your photo library to update your profile picture.",
        "NSCameraUsageDescription": "FutureIntern needs access to your camera to take a profile photo.",
        "NSPhotoLibraryAddUsageDescription": "FutureIntern saves your profile photo to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/futureintern-logo.jpg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.futureintern.app",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f43f5e"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "FutureIntern needs access to your photos to update your profile picture.",
          "cameraPermission": "FutureIntern needs camera access to take a profile photo."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://futureintern-production.up.railway.app/api"
    }
  }
}
